{
  "name": "product-list-app",
  "version": "1.0.0",
  "description": "Product list app using Handlebars and Express",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "node server.js",
    "build": "webpack --mode development",
    "watch": "webpack --watch",
    "dev": "concurrently \"npm run server\" \"npm run build --watch\"\"nodemon server.js\""
  },
  "dependencies": {
    "express": "^4.17.1",
    "express-handlebars": "^8.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "babel-loader": "^9.2.1",
    "concurrently": "^9.1.0",
    "css-loader": "^7.1.2",
    "file-loader": "^6.2.0",
    "handlebars-loader": "^1.7.3",
    "mini-css-extract-plugin": "^2.9.2",
    "nodemon": "^3.1.7",
    "sass": "^1.82.0",
    "sass-loader": "^16.0.4",
    "style-loader": "^4.0.0",
    "webpack": "^5.97.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.1.0"
  }
}
